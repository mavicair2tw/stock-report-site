<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.william.stockreport.email</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/mavicair2tw/.openclaw/workspace/stock-report-site-repo/stock-report-site &amp;&amp; ./.venv/bin/python scripts/send_daily_email.py</string>
  </array>

  <key>StartCalendarInterval</key>
