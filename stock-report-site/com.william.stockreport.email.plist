    <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>13</integer><key>Minute</key><integer>31</integer></dict>
    <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>13</integer><key>Minute</key><integer>31</integer></dict>
    <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>13</integer><key>Minute</key><integer>31</integer></dict>
  </array>

  <key>StandardOutPath</key>
  <string>/Users/mavicair2tw/.openclaw/workspace/stock-report-site/logs/email.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/mavicair2tw/.openclaw/workspace/stock-report-site/logs/email.err.log</string>

  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
